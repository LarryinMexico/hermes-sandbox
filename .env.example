# Codespaces Secrets required for this repo
# Set these at: GitHub → Settings → Codespaces → Secrets

# Your Telegram bot token from BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your OpenRouter API key (free at openrouter.ai)
OPENROUTER_API_KEY=sk-or-...

# GitHub Personal Access Token (scope: repo, workflow)
# Used by Hermes to create new repos on your behalf
GH_PAT=ghp_...
